{
  "experiment_name": "anime_hybrid_pytorch",
  "framework": "pytorch",
  "seed": 42,
  "positive_rating_threshold": 8,
  "target_user_count": 1500,
  "minimum_user_positives_before_sampling": 20,
  "maximum_user_positives_before_sampling": 300,
  "minimum_user_positives_after_filtering": 15,
  "minimum_item_users": 5,
  "validation_fraction": 0.1,
  "test_fraction": 0.1,
  "recommendation_k": 10,
  "optuna_trials": 15,
  "device": "cpu",
  "candidate_objectives": [
    "logistic",
    "bpr",
    "warp_style_hard_negative"
  ],
  "item_metadata": [
    "genre",
    "type"
  ],
  "primary_metric": "precision_at_10",
  "sampled_auc_negatives": 100,
  "default_training": {
    "latent_dim": 32,
    "epochs": 8,
    "batch_size": 4096,
    "learning_rate": 0.01,
    "weight_decay": 1e-06,
    "metadata_weight": 1.0,
    "negatives_per_positive": 1,
    "max_sampled": 10,
    "margin": 1.0,
    "gradient_clip_norm": 5.0,
    "scoring_user_batch_size": 128
  }
}
